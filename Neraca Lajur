<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Neraca Lajur</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background-color: #f3e8ff;
    }
    .header {
      background-color: #6f42c1;
      color: white;
      padding: 20px;
      text-align: center;
      border-radius: 10px;
      margin-bottom: 20px;
    }
    .table thead {
      background-color: #6f42c1;
      color: white;
    }
    .table tbody tr:hover {
      background-color: #ede0ff;
    }
    .card {
      border-radius: 15px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .btn-purple {
      background-color: #6f42c1;
      color: white;
    }
    .btn-purple:hover {
      background-color: #5a34a3;
      color: white;
    }
  </style>
</head>
<body>

<div class="container mt-4">
  <div class="header">
    <h2>Neraca Lajur (Worksheet)</h2>
    <p>Sistem Akuntansi Sederhana</p>
  </div>

  <div class="card p-4">
    <table class="table table-bordered text-center align-middle">
      <thead>
        <tr>
          <th rowspan="2">No</th>
          <th rowspan="2">Nama Akun</th>
          <th colspan="2">Neraca Saldo</th>
          <th colspan="2">Penyesuaian</th>
          <th colspan="2">Neraca Disesuaikan</th>
          <th colspan="2">Laba Rugi</th>
          <th colspan="2">Neraca</th>
        </tr>
        <tr>
          <th>Debit</th>
          <th>Kredit</th>
          <th>Debit</th>
          <th>Kredit</th>
          <th>Debit</th>
          <th>Kredit</th>
          <th>Debit</th>
          <th>Kredit</th>
          <th>Debit</th>
          <th>Kredit</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>1</td>
          <td>Kas</td>
          <td>10.000</td>
          <td></td>
          <td></td>
          <td></td>
          <td>10.000</td>
          <td></td>
          <td></td>
          <td></td>
          <td>10.000</td>
          <td></td>
        </tr>
        <tr>
          <td>2</td>
          <td>Perlengkapan</td>
          <td>5.000</td>
          <td></td>
          <td></td>
          <td></td>
          <td>5.000</td>
          <td></td>
          <td></td>
          <td></td>
          <td>5.000</td>
          <td></td>
        </tr>
      </tbody>
    </table>

    <div class="text-end mt-3">
      <button class="btn btn-purple">Simpan Data</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
